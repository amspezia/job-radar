# Job Radar — configuration contract.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file is
# the committed source of truth for what the system needs. No real secrets here.

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql+psycopg://job_radar:job_radar@localhost:5432/job_radar

# --- Local models via Ollama (zero-cost dev path) ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
GENERATION_MODEL=qwen2.5

# --- Paid LLM API (final quality pass; leave key empty for local-only dev) ---
LLM_API_KEY=
LLM_API_MODEL=gpt-4o-mini

# --- Observability (Langfuse + OpenTelemetry) ---
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_HOST=http://localhost:3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- App ---
LOG_LEVEL=INFO
